{
	"name": "@atprotobrew/common",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "expo start -c",
		"android": "expo start -c --android",
		"ios": "expo start -c --ios",
		"web": "expo start -c --web",
		"clean": "rm -rf .expo node_modules",
		"i18n:extract": "lingui extract",
		"i18n:compile": "lingui compile"
	},
	"exports": {
		"./alf": {
			"import":"./src/styles/alf/index.ts"
		},
		"./core/components/*": {
			"import": "./src/core/components/*.tsx"
		},
		"./core/modules/*": {
			"import": "./src/core/modules/*.ts"
		},
		"./core/stores/*": {
			"import": "./src/core/stores/*.ts"
		},
		"./core/types/*": {
			"import": "./src/core/types/*.ts"
		},
		"./theme": {
			"import": "./src/styles/theme/index.ts"
		},
		"./auth/components/*": {
			"import": "./src/features/auth/components/*.tsx"
		},
		"./channel/components/*": {
			"import": "./src/features/channel/components/*.tsx"
		},
		"./channel/modules/*": {
			"import": "./src/features/channel/modules/*.ts"
		},
		"./store/components/*": {
			"import": "./src/features/store/components/*.tsx"
		},
		"./i18n/locales/*": {
			"import": "./locales/*/messages.ts"
		}
	},
	"dependencies": {
		"@atpassport/client": "^0.1.31",
		"@atprotobrew/tokens": "workspace:^",
		"@atprotobrew/atproto": "workspace:^",
		"@react-navigation/native": "^7.0.0",
		"@tamagui/animations-react-native": "2.0.0-rc.41",
		"@tamagui/config": "2.0.0-rc.41",
		"@tamagui/core": "2.0.0-rc.41",
		"@tanstack/react-form": "^1.29.1",
		"@tanstack/react-query": "^5.100.9",
		"class-variance-authority": "^0.7.1",
		"date-fns": "^4.1.0",
		"expo": "~55.0.9",
		"expo-constants": "~55.0.9",
		"expo-linking": "~55.0.9",
		"expo-router": "~55.0.8",
		"expo-splash-screen": "~55.0.13",
		"expo-status-bar": "~55.0.4",
		"expo-system-ui": "~55.0.11",
		"jotai": "^2.20.0",
		"lucide-react-native": "^0.545.0",
		"react-native": "0.83.6",
		"react-native-mmkv": "^2.12.2",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.23.0",
		"react-native-svg": "^15.15.3",
		"tamagui": "2.0.0-rc.41",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@babel/core": "^7.26.0",
		"@types/react": "~19.2.10",
		"typescript": "^6.0.3"
	},
	"private": true
}
