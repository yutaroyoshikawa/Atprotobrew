{
	"name": "@atprotobrew/common",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "expo start -c",
		"android": "expo start -c --android",
		"ios": "expo start -c --ios",
		"web": "expo start -c --web",
		"clean": "rm -rf .expo node_modules",
		"i18n:extract": "lingui extract",
		"i18n:compile": "lingui compile"
	},
	"exports": {
		"./alf": {
			"import": "./src/styles/alf/index.ts"
		},
		"./core/components/*": {
			"import": "./src/core/components/*.tsx"
		},
		"./core/modules/*": {
			"import": "./src/core/modules/*.ts"
		},
		"./core/stores/*": {
			"import": "./src/core/stores/*.ts"
		},
		"./core/types/*": {
			"import": "./src/core/types/*.ts"
		},
		"./theme": {
			"import": "./src/styles/theme/index.ts"
		},
		"./auth/components/*": {
			"import": "./src/features/auth/components/*.tsx"
		},
		"./channel/components/*": {
			"import": "./src/features/channel/components/*.tsx"
		},
		"./channel/modules/*": {
			"import": "./src/features/channel/modules/*.ts"
		},
		"./store/components/*": {
			"import": "./src/features/store/components/*.tsx"
		},
		"./settings/components/*": {
			"import": "./src/features/settings/components/*.tsx"
		},
		"./i18n/locales/*": {
			"import": "./locales/*/messages.ts"
		},
		"./launcher/*": {
			"import": "./src/features/launcher/*.ts"
		},
		"./user/modules/*": {
			"import": "./src/features/user/modules/*.ts"
		},
		"./user/components/*": {
			"import": "./src/features/user/components/*.tsx"
		},
		"./account/*": {
			"import": "./src/features/account/*.ts"
		}
	},
	"dependencies": {
		"@atpassport/client": "^0.1.31",
		"@atprotobrew/atproto": "workspace:^",
		"@atprotobrew/tokens": "workspace:^",
		"@expo/ui": "~56.0.14",
		"@react-native-async-storage/async-storage": "^2.2.0",
		"@tamagui/animations-react-native": "2.0.0",
		"@tamagui/config": "2.0.0",
		"@tamagui/core": "2.0.0",
		"@tanstack/react-form": "^1.29.1",
		"@tanstack/react-query": "^5.100.9",
		"chroma-js": "^3.2.0",
		"class-variance-authority": "^0.7.1",
		"date-fns": "^4.1.0",
		"expo": "56.0.8",
		"expo-blur": "~56.0.3",
		"expo-constants": "~56.0.16",
		"expo-linking": "~56.0.12",
		"expo-router": "~56.2.7",
		"expo-splash-screen": "~56.0.10",
		"expo-status-bar": "~56.0.4",
		"expo-system-ui": "~56.0.5",
		"jotai": "^2.20.0",
		"jotai-family": "^1.0.2",
		"lucide-react-native": "^1.16.0",
		"qrcode": "^1.5.4",
		"react-native": "0.85.3",
		"react-native-mmkv": "^3.3.3",
		"react-native-safe-area-context": "~5.7.0",
		"react-native-screens": "4.25.2",
		"react-native-svg": "15.15.5",
		"react-native-tab-view": "^4.3.1",
		"react-native-teleport": "^1.1.7",
		"tamagui": "2.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@babel/core": "^7.26.0",
		"@types/chroma-js": "^3.1.2",
		"@types/qrcode": "^1.5.6",
		"@types/react": "~19.2.10",
		"typescript": "^6.0.3"
	},
	"private": true
}
