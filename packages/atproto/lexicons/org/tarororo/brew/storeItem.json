{
	"lexicon": 1,
	"id": "org.tarororo.brew.storeItem",
	"defs": {
		"main": {
			"type": "record",
			"description": "",
			"key": "any",
			"record": {
				"type": "object",
				"required": ["title", "description", "author", "launch", "thumbnail"],
				"properties": {
					"title": {
						"type": "string"
					},
					"description": {
						"type": "string"
					},
					"author": {
						"type": "string"
					},
					"launch": {
						"type": "union",
						"refs": ["#launchWeb", "#launchStore"]
					},
					"thumbnail": {
						"type": "blob"
					}
				}
			}
		},
		"launchWeb": {
			"type": "object",
			"required": ["link"],
			"properties": {
				"link": {
					"type": "string",
					"format": "uri"
				}
			}
		},
		"launchStore": {
			"type": "object",
			"required": [],
			"properties": {}
		}
	}
}
