{
	"lexicon": 1,
	"id": "org.tarororo.brew.getLauncher",
	"defs": {
		"main": {
			"type": "query",
			"description": "",
			"parameters": {
				"type": "params",
				"properties": {}
			},
			"output": {
				"schema": {
					"type": "object",
					"required": ["view", "record"],
					"properties": {
						"view": {
							"type": "ref",
							"ref": "#launcherView"
						},
						"record": {
							"type": "unknown"
						}
					}
				},
				"encoding": "application/json"
			}
		},
		"launcherView": {
			"type": "array",
			"items": {
				"type": "ref",
				"ref": "#launcherViewItem"
			}
		},
		"launcherViewItem": {
			"type": "object",
			"required": ["title", "description", "author", "launch", "thumbnail", "uri", "record"],
			"properties": {
				"title": {
					"type": "string"
				},
				"description": {
					"type": "string"
				},
				"author": {
					"type": "string"
				},
				"launch": {
					"type": "union",
					"refs": ["org.tarororo.brew.storeItem#launchWeb", "org.tarororo.brew.storeItem#launchStore"]
				},
				"thumbnail": {
					"type": "string",
					"format": "uri"
				},
				"uri": {
					"type": "string",
					"format": "at-uri"
				},
				"record": {
					"type": "unknown"
				}
			}
		}
	}
}
