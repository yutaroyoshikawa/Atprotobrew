{
	"name": "atprotobrew",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"app": "pnpm -F 'atprotobrew-app'",
		"web": "pnpm -F 'atprotobrew-web'",
		"common": "pnpm -F 'common'",
		"back": "pnpm -F 'back'",
		"atproto": "pnpm -F 'atproto'",
		"tokens": "pnpm -D 'tokens'",
		"check": "biome check --write --staged",
		"postinstall": "node -e \"const fs=require('fs'),path=require('path');const src=path.resolve('node_modules/@expo/expo-modules-macros-plugin');const dest=path.resolve('node_modules/expo-modules-core/node_modules/@expo/expo-modules-macros-plugin');fs.mkdirSync(path.dirname(dest),{recursive:true});if(!fs.existsSync(dest)){fs.symlinkSync(src,dest,'dir');console.log('[postinstall] Created symlink: expo-modules-core/node_modules/@expo/expo-modules-macros-plugin');}else{console.log('[postinstall] Symlink already exists');}\" 2>/dev/null || true"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"packageManager": "pnpm@10.32.1",
	"dependencies": {
		"@atproto/lex": "^0.0.25",
		"@biomejs/biome": "2.2.3",
		"@lingui/core": "^6.0.1",
		"@lingui/react": "^6.0.1",
		"react": "19.2.3",
		"react-native": "0.85.3",
		"react-native-svg": "15.15.5",
		"wrangler": "4.82.0"
	},
	"pnpm": {
		"overrides": {
			"react": "19.2.3",
			"react-dom": "19.2.3",
			"react-native": "0.85.3",
			"react-native-svg": "15.15.4",
			"react-native-worklets": "0.8.3",
			"@expo/dom-webview": "56.0.5",
			"@expo/metro-runtime": "56.0.13",
			"@expo/log-box": "56.0.12",
			"expo-web-browser": "56.0.5",
      "expo": "56.0.6",
			"react-native-mmkv": "3.3.3",
			"@babel/helper-compilation-targets>lru-cache": "5"
		},
		"configDependencies": {
			"@pnpm/pacquet": "0.2.9+sha512-mQnzMQ+7VD04hfINjIMJzSRJsPtATEKs7M2X+Hl4YaQDo4488DD+q9rBgMSc2+JmTseiRJmtNXcbzrOfzsXC5Q=="
		}
	},
	"devDependencies": {
		"@types/node": "^24.12.2"
	}
}
