{
	"$schema": "https://biomejs.dev/schemas/2.2.3/schema.json",
	"extends": ["./shared/biome.jsonc"],
	"files": {
		"includes": [
			"**",
			"!**/worker-configuration.d.ts",
			"!**/node_modules/**/*",
			"!**/dist/**/*",
			"!**/lexicons/**/*"
		]
	},
	"linter": {
		"rules": {
			"suspicious": { "noUnknownAtRules": "off", "noConfusingVoidType": "info" },
			"correctness": { "noUnknownTypeSelector": "off", "useExhaustiveDependencies": "info" },
			"complexity": { "noBannedTypes": "off", "noStaticOnlyClass": "off" }
		}
	}
}
