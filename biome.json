{
	"$schema": "https://biomejs.dev/schemas/2.2.3/schema.json",
	"extends": ["./shared/biome.jsonc"],
	"files": {
		"includes": [
			"**",
			"!**/worker-configuration.d.ts",
			"!**/node_modules/**/*",
			"!**/dist/**/*",
			"!**/lexicons/**/*.ts",
			"!**/lexicons/**/*.json",
			"!**/tokens/build/**/*.ts",
			"!**/tokens/build/**/*.css",
			"!**/storybook.requires.ts"
		]
	},
	"linter": {
		"rules": {
			"suspicious": {
				"noUnknownAtRules": "off",
				"noExplicitAny": "error",
				"noImplicitAnyLet": "error",
				"noEvolvingTypes": "error"
			},
			"correctness": {
				"noUnknownTypeSelector": "off",
				"useExhaustiveDependencies": {
					"level": "info",
					"options": {
						"hooks": [{ "name": "useEffectEvent", "stableResult": true }]
					}
				}
			},
			"complexity": { "noBannedTypes": "off", "noStaticOnlyClass": "off" },
			"style": { "useBlockStatements": "error" }
		}
	}
}
